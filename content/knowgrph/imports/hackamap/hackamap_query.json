{
  "query": {
    "from": {
      "files": [
        "events.md",
        "demos.md",
        "sources.md",
        "organizer.md",
        "team.md",
        "techstack.md"
      ]
    },
    "where_by_file": {
      "events.md": {
        "or": [
          {
            "and": [
              { "field": "Location", "op": "contains", "value": "Singapore" },
              { "field": "Confidence", "op": "in", "value": ["high", "medium"] }
            ]
          },
          {
            "or": [
              { "op": "any", "value": "openai" },
              { "op": "any", "value": "anthropic" },
              { "op": "any", "value": "claude" },
              { "op": "any", "value": "codex" },
              { "op": "any", "value": "gpt" },
              { "op": "any", "value": "gemini" },
              { "op": "any", "value": "google" },
              { "op": "any", "value": "deepmind" },
              { "op": "any", "value": "openclaw" },
              { "op": "any", "value": "mcp" },
              { "op": "any", "value": "cursor" },
              { "op": "any", "value": "vercel" },
              { "op": "any", "value": "supabase" },
              { "op": "any", "value": "postgres" }
            ]
          },
          {
            "or": [
              { "field": "Organizer", "op": "contains", "value": "GovTech" },
              { "field": "Organizer", "op": "contains", "value": "NUS" },
              { "field": "Organizer", "op": "contains", "value": "NTU" },
              { "field": "Organizer", "op": "contains", "value": "SMU" },
              { "field": "Organizer", "op": "contains", "value": "SUTD" },
              { "field": "Organizer", "op": "contains", "value": "BLOCK71" }
            ]
          }
        ]
      },
      "demos.md": {
        "or": [
          {
            "and": [
              { "field": "Confidence", "op": "in", "value": ["high", "medium"] }
            ]
          },
          {
            "or": [
              { "op": "any", "value": "openai" },
              { "op": "any", "value": "anthropic" },
              { "op": "any", "value": "claude" },
              { "op": "any", "value": "codex" },
              { "op": "any", "value": "gpt" },
              { "op": "any", "value": "gemini" },
              { "op": "any", "value": "google" },
              { "op": "any", "value": "deepmind" },
              { "op": "any", "value": "openclaw" },
              { "op": "any", "value": "mcp" },
              { "op": "any", "value": "cursor" },
              { "op": "any", "value": "vercel" },
              { "op": "any", "value": "supabase" }
            ]
          }
        ]
      },
      "sources.md": {
        "or": [
          {
            "or": [
              { "field": "Domain", "op": "contains", "value": "devpost" },
              { "field": "Domain", "op": "contains", "value": "github" },
              { "field": "Domain", "op": "contains", "value": "linkedin" },
              { "field": "Domain", "op": "contains", "value": "x.com" },
              { "field": "URL", "op": "contains", "value": "luma.com" }
            ]
          },
          {
            "or": [
              { "op": "any", "value": "openai" },
              { "op": "any", "value": "anthropic" },
              { "op": "any", "value": "claude" },
              { "op": "any", "value": "google" },
              { "op": "any", "value": "openclaw" }
            ]
          }
        ]
      },
      "organizer.md": {
        "or": [
          { "field": "Organizer", "op": "contains", "value": "OpenAI" },
          { "field": "Organizer", "op": "contains", "value": "Anthropic" },
          { "field": "Organizer", "op": "contains", "value": "Google" },
          { "field": "Organizer", "op": "contains", "value": "DeepMind" },
          { "field": "Organizer", "op": "contains", "value": "OpenClaw" },
          { "field": "Organizer", "op": "contains", "value": "GovTech" }
        ]
      },
      "team.md": {
        "or": [
          { "field": "Team", "op": "contains", "value": "OpenAI" },
          { "field": "Team", "op": "contains", "value": "Anthropic" },
          { "field": "Team", "op": "contains", "value": "Google" },
          { "field": "Team", "op": "contains", "value": "DeepMind" },
          { "field": "Team", "op": "contains", "value": "OpenClaw" },
          { "field": "Team", "op": "contains", "value": "GovTech" }
        ]
      },
      "techstack.md": {
        "or": [
          { "field": "Tech", "op": "contains", "value": "OpenAI" },
          { "field": "Tech", "op": "contains", "value": "Anthropic" },
          { "field": "Tech", "op": "contains", "value": "Claude" },
          { "field": "Tech", "op": "contains", "value": "Codex" },
          { "field": "Tech", "op": "contains", "value": "Gemini" },
          { "field": "Tech", "op": "contains", "value": "Google" },
          { "field": "Tech", "op": "contains", "value": "OpenClaw" },
          { "field": "Tech", "op": "contains", "value": "MCP" },
          { "field": "Vendor/Org", "op": "contains", "value": "OpenAI" },
          { "field": "Vendor/Org", "op": "contains", "value": "Google" },
          { "field": "Vendor/Org", "op": "contains", "value": "Anthropic" }
        ]
      }
    },
    "limit": 200,
    "output": {
      "title": "hackamap-enhanced-query-results",
      "json_path": "hackamap-enhanced-query-results.json",
      "md_path": "hackamap-enhanced-query-results.md"
    }
  }
}

