/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Permissions-Policy: camera=(), microphone=(), payment=(), usb=(), interest-cohort=(), geolocation=(self), fullscreen=(self)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: blob: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://api.openai.com https://ark.ap-southeast.bytepluses.com https://zenmux.ai https://publish.twitter.com https://platform.twitter.com https://www.linkedin.com https://www.reddit.com https://www.redditmedia.com; frame-src 'self' https://platform.twitter.com https://www.linkedin.com; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests; block-all-mixed-content

/index.html
  Cache-Control: no-store

/assets/boot.js
  Cache-Control: no-store

/assets/overrides.css
  Cache-Control: no-store

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/boards/*
  Cache-Control: public, max-age=300, must-revalidate

/script-*.json
  Cache-Control: public, max-age=60, must-revalidate

# Cloudflare Pages requests are often rewritten from /singabldr/* -> /* via _redirects.
# Define both path forms so headers apply regardless of rewrite order.
/singabldr/assets/*
  Cache-Control: public, max-age=31536000, immutable

/singabldr/boards/*
  Cache-Control: public, max-age=300, must-revalidate

/singabldr/script-*.json
  Cache-Control: public, max-age=60, must-revalidate
