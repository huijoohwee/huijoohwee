/index.html
  Cache-Control: no-store

/assets/boot.js
  Cache-Control: no-store

/assets/overrides.css
  Cache-Control: no-store

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/boards/*
  Cache-Control: public, max-age=300, must-revalidate

/script-*.json
  Cache-Control: public, max-age=60, must-revalidate

# Cloudflare Pages requests are often rewritten from /singabldr/* -> /* via _redirects.
# Define both path forms so headers apply regardless of rewrite order.
/singabldr/assets/*
  Cache-Control: public, max-age=31536000, immutable

/singabldr/boards/*
  Cache-Control: public, max-age=300, must-revalidate

/singabldr/script-*.json
  Cache-Control: public, max-age=60, must-revalidate

