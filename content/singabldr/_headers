/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Permissions-Policy: camera=(), microphone=(), payment=(), usb=(), interest-cohort=(), geolocation=(self), fullscreen=(self)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # NOTE: Do NOT set CSP here. CSP is defined centrally at repo root (_headers)
  # for /content/singabldr/* and /singabldr/* so browsers don't receive multiple
  # Content-Security-Policy headers (which would enforce the intersection).

/index.html
  Cache-Control: no-store

/assets/boot.js
  Cache-Control: no-store

/assets/boot-sim-engine.js
  Cache-Control: no-store

/assets/overrides.css
  Cache-Control: no-store

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/boards/*
  Cache-Control: public, max-age=300, must-revalidate

/script-*.json
  Cache-Control: public, max-age=60, must-revalidate

# Cloudflare Pages requests are often rewritten from /singabldr/* -> /* via _redirects.
# Define both path forms so headers apply regardless of rewrite order.
/singabldr/assets/*
  Cache-Control: public, max-age=31536000, immutable

/singabldr/boards/*
  Cache-Control: public, max-age=300, must-revalidate

/singabldr/script-*.json
  Cache-Control: public, max-age=60, must-revalidate
