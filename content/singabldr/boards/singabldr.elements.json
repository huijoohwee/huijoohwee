{
  "version": "singabldr-elements@1",
  "geographic_features": {
    "coastline": { "type": "polygon", "source": "scene.polygons[mainPolygonIndex]" },
    "islands": [
      { "id": "jurong_island", "label": "Jurong Island", "source": "scene.polygons[1]" },
      { "id": "sentosa", "label": "Sentosa", "source": "scene.polygons[2]" },
      { "id": "pulau_ubin", "label": "Pulau Ubin", "source": "scene.polygons[3]" },
      { "id": "pulau_tekong", "label": "Pulau Tekong", "source": "scene.polygons[4]" }
    ]
  },
  "points_of_interest": {
    "mbs": { "kind": "landmark", "model": "skyscraper", "focus": true, "tags": ["marina_bay", "hotel", "skypark"] },
    "gbtb": { "kind": "landmark", "model": "park", "focus": true, "tags": ["nature", "gardens"] },
    "merlion": { "kind": "monument", "model": "monument", "focus": true, "tags": ["tourism"] },
    "sentosa": { "kind": "island", "model": "park", "focus": true, "tags": ["beach", "resort"] },
    "chinatown": { "kind": "district", "model": "mall", "focus": false, "tags": ["food", "heritage"] },
    "orchard": { "kind": "district", "model": "mall", "focus": false, "tags": ["shopping"] },
    "littleindia": { "kind": "district", "model": "monument", "focus": false, "tags": ["heritage"] },
    "civic_district": { "kind": "district", "model": "monument", "focus": false, "tags": ["culture_heritage", "architecture"] },
    "kampong_gelam": { "kind": "district", "model": "monument", "focus": false, "tags": ["culture_heritage", "street_culture"] },
    "katong_joo_chiat": { "kind": "district", "model": "mall", "focus": false, "tags": ["culture_heritage", "food"] },
    "singapore_river": { "kind": "district", "model": "monument", "focus": false, "tags": ["nightlife", "river_cruise"] },
    "mandai": { "kind": "district", "model": "park", "focus": false, "tags": ["city_in_nature", "wildlife"] },
    "dempsey": { "kind": "district", "model": "mall", "focus": false, "tags": ["heritage", "lifestyle"] },
    "marina_barrage": { "kind": "landmark", "model": "monument", "focus": false, "tags": ["marina_bay", "sustainability", "city_in_nature"] },
    "artscience_museum": { "kind": "landmark", "model": "monument", "focus": false, "tags": ["marina_bay", "culture_heritage", "architecture"] },
    "bird_paradise": { "kind": "attraction", "model": "park", "focus": false, "tags": ["family_fun", "wildlife", "mandai"] },
    "rainforest_wild_asia": { "kind": "attraction", "model": "park", "focus": false, "tags": ["unique_experiences", "wildlife", "mandai"] },
    "pulau_ubin_kayaking": { "kind": "experience", "model": "park", "focus": false, "tags": ["city_in_nature", "adventure", "pulau_ubin"] },
    "synthesis_bar": { "kind": "experience", "model": "mall", "focus": false, "tags": ["novelty", "nightlife"] },
    "trifecta": { "kind": "experience", "model": "mall", "focus": false, "tags": ["novelty", "unique_experiences"] }
  },
  "transportation": {
    "mrt": { "kind": "rail", "path": "nodes", "defaultSpeed": 0.008, "yOffset": 8, "supports": ["start", "stop", "faster"] },
    "plane": { "kind": "air", "path": "circular", "radius": 220, "y": 120, "defaultSpeed": 0.004, "supports": ["start", "stop", "faster"] },
    "heli": { "kind": "air", "path": "patrol", "y": 60, "defaultSpeed": 0.05, "supports": ["start", "stop"] },
    "ship": { "kind": "sea", "path": "circular", "radius": 300, "y": -3, "defaultSpeed": 0.002, "supports": ["start", "stop"] },
    "rocket": { "kind": "space", "path": "launch", "supports": ["launch"] }
  },
  "nature": {
    "citizens": {
      "defaultSentiment": "neutral",
      "sentiments": ["neutral", "happy"],
      "bubbleTriggers": ["react", "bubble", "url", "file"],
      "bubbleTemplates": {
        "react:heard": "Did you hear about “{snippet}”?",
        "react:file": "I just read “{snippet}”.",
        "react:url": "I saw this on {domain}…",
        "poi:visit": "Let’s go to {poi}!",
        "swarm:status": "Swarm status: {status}",
        "swarm:burst": "Agents everywhere! 🤖",
        "weather:change": "Weather update: {weather}",
        "theme:change": "Theme update: {theme}",
        "ai:news:ask": "Any hot AI news today? 👀",
        "ai:news:hot": "AI buzz: {snippet}",
        "ai:sg:pulse": "Singapore AI pulse: {snippet}",
        "ai:agents:swarm": "Swarm idea: {snippet}",
        "ai:tools:tip": "Tool tip: {snippet}"
      }
    },
    "clouds": { "drift": { "enabled": true } },
    "trees": { "placement": { "mode": "landOnly" } }
  },
  "swarm": {
    "version": "swarm@1",
    "agents": [
    { "id": "flowinfish", "role": "superagent", "tags": ["local-llm", "local-sim"] },
      { "id": "citizen_swarm", "role": "swarm_engine", "tags": ["bubbles", "sentiment", "poi"] }
    ],
    "loops": {
      "default": { "burstEverySeconds": 15, "maxBubblesPerBurst": 4, "intensityRange": [0.3, 1.0] }
    }
  },
  "ai": {
    "debateRoles": ["Pro", "Con", "Policy", "Builder", "Neutral"],
    "topics": [
      "agentic workflows",
      "swarm intelligence",
      "RAG and retrieval",
      "evaluation and benchmarks",
      "multimodal models",
      "on-device AI",
      "AI safety and governance",
      "Singapore AI governance (AI Verify, IMDA)",
      "GovTech and public sector AI",
      "NUS/NTU research",
      "A*STAR research",
      "AI in finance",
      "AI in logistics",
      "AI in healthcare"
    ],
    "newsHints": [
      "new model releases",
      "open-source agent frameworks",
      "AI regulation updates",
      "agent tooling (orchestration, memory, evals)",
      "Singapore initiatives and funding"
    ]
  },
  "theme": {
    "default": { "mix": 0, "snow": false },
    "christmas": { "mix": 0.6, "snow": true },
    "deepavali": { "mix": 0.4, "snow": false },
    "cny": { "mix": 0.4, "snow": false },
    "hari_raya": { "mix": 0.4, "snow": false },
    "national_day": { "mix": 0.55, "snow": false },
    "heritage": { "mix": 0.25, "snow": false },
    "city_in_nature": { "mix": 0.22, "snow": false },
    "novelty": { "mix": 0.28, "snow": false }
  },
  "events": {
    "seasonal": [
      { "id": "hari_raya_haji", "kind": "festival", "tags": ["culture_heritage"] },
      { "id": "vesak_day", "kind": "festival", "tags": ["culture_heritage"] },
      { "id": "dragon_boat_festival", "kind": "festival", "tags": ["culture_heritage"] },
      { "id": "national_day", "kind": "festival", "tags": ["novelty", "iconic_architecture"] }
    ]
  },
  "weather": {
    "sunshine": { "effects": [] },
    "cloudy": { "effects": [] },
    "stormy": { "effects": ["wind"] },
    "haze": { "effects": ["haze"] }
  },
  "animation": {
    "citizen_bubble": { "fadeInMs": 10, "fadeOutMs": 300, "projectToScreen": true },
    "vehicle_motion": { "ease": "linear", "speedMultiplierCap": 8 },
    "interactions": {
      "rollDice": { "cooldownMs": 1200 },
      "camera": { "tweenMs": 900 },
      "poiHighlight": { "pulseMs": 1200 }
    },
    "presets": {
      "infinitown_like": {
        "sceneRotation": { "enabled": true, "speedY": 0.0012 },
        "cameraOrbit": { "enabled": false, "radius": 520, "height": 260, "speed": 0.06 },
        "vehicleBob": { "enabled": true, "amp": 0.25, "speed": 2.0 }
      }
    }
  },
  "interactivity": {
    "style": "infinitown_like",
    "sceneRotation": { "enabled": false, "speedY": 0.0012 },
    "cameraOrbit": {
      "enabled": true,
      "overrideCamera": true,
      "radius": 520,
      "height": 260,
      "speed": 0.06,
      "target": [0, 0, 0]
    },
    "focus": {
      "enabled": true,
      "preferPoi": true,
      "preferVehicles": true
    }
  }
}
