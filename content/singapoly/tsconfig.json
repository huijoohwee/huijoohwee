{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*", "../knowgrph/canvas/src/*"],
      "maplibre-gl": ["../knowgrph/canvas/node_modules/maplibre-gl"],
      "maplibre-gl/*": ["../knowgrph/canvas/node_modules/maplibre-gl/*"]
    },
    "types": []
  },
  "include": ["src"]
}
