/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), autoplay=(), camera=(), clipboard-read=(), clipboard-write=(), display-capture=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob: https:; font-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' https://static.cloudflareinsights.com; connect-src 'self' https: https://static.cloudflareinsights.com; frame-src 'self' https: data: blob:; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests

/content/singabldr/*
  # Strict CSP: no inline scripts. Singabldr boot logic is externalized to ./assets/boot.js.
  # Stricter: disallow all WebSockets (multiplayer disabled in production).
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob: https:; font-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' https://static.cloudflareinsights.com; connect-src 'self' https: https://static.cloudflareinsights.com; frame-src 'self' https: data: blob:; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests

/singabldr/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob: https:; font-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' https://static.cloudflareinsights.com; connect-src 'self' https: https://static.cloudflareinsights.com; frame-src 'self' https: data: blob:; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests

/content/knowgrph/index.html
  Cache-Control: public, max-age=0, must-revalidate

/knowgrph
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/knowgrph/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/knowgrph/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/content/knowgrph/*.json
  Cache-Control: public, max-age=0, must-revalidate

/content/singabldr/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Singabldr is also served via "pretty" paths (/ and /singabldr/*) using _redirects rewrites.
# Ensure HTML is never cached aggressively (prevents stale index.html referencing missing hashed assets),
# while allowing hashed assets to be cached immutably for performance.
/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/singabldr
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/singabldr/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/singabldr/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/singabldr/assets/*
  Cache-Control: public, max-age=31536000, immutable

/singabldr/boards/*.json
  Cache-Control: public, max-age=0, must-revalidate

/content/*/assets/*
  Cache-Control: public, max-age=31536000, immutable

/content/*/vendor/*
  Cache-Control: public, max-age=31536000, immutable

/content/singabldr/boards/*.json
  Cache-Control: public, max-age=0, must-revalidate

/content/singabldr/*.json
  Cache-Control: public, max-age=0, must-revalidate
