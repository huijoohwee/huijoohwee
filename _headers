/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-DNS-Prefetch-Control: off
  X-Permitted-Cross-Domain-Policies: none
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Permissions-Policy: accelerometer=(), autoplay=(), camera=(), clipboard-read=(), clipboard-write=(), display-capture=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # NOTE: Do NOT set a global CSP here.
  # Cloudflare Pages will emit multiple Content-Security-Policy headers when both `/*`
  # and a more specific path define CSP. Browsers enforce the intersection, which can
  # silently break Singabldr (and Safari) by blocking scripts.
  # Set CSP only on the specific app paths below.

/content/singabldr/*
  # Strict CSP: no inline scripts. Singabldr boot logic is externalized to ./assets/boot.js.
  # Stricter: disallow all WebSockets (multiplayer disabled in production).
  # NOTE: This CSP intentionally forbids inline scripts. If Cloudflare features inject inline snippets
  # (e.g. Zaraz), disable them for this Pages project rather than weakening CSP.
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'none'; img-src 'self' data: blob: https:; font-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' https://static.cloudflareinsights.com; script-src-attr 'none'; connect-src 'self' https://static.cloudflareinsights.com; frame-src 'self' https: data: blob:; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests; block-all-mixed-content

/singabldr/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'none'; img-src 'self' data: blob: https:; font-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' https://static.cloudflareinsights.com; script-src-attr 'none'; connect-src 'self' https://static.cloudflareinsights.com; frame-src 'self' https: data: blob:; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests; block-all-mixed-content

/content/knowgrph/index.html
  Cache-Control: public, max-age=0, must-revalidate

/knowgrph
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/knowgrph/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/knowgrph/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/knowgrph/*.json
  Cache-Control: public, max-age=0, must-revalidate

/knowgrph/assets/*
  Cache-Control: public, max-age=31536000, immutable

/knowgrph/vendor/*
  Cache-Control: public, max-age=31536000, immutable

/knowgrph/*
  Content-Security-Policy-Report-Only: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob: https:; font-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://static.cloudflareinsights.com; script-src-attr 'none'; connect-src 'self' https: wss:; frame-src 'self' https: data: blob:; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests

/content/knowgrph/*.json
  Cache-Control: public, max-age=0, must-revalidate

/content/singabldr/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Singabldr is also served via "pretty" paths (/ and /singabldr/*) using _redirects rewrites.
# Ensure HTML is never cached aggressively (prevents stale index.html referencing missing hashed assets),
# while allowing hashed assets to be cached immutably for performance.
/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/singabldr
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/singabldr/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/singabldr/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/singabldr/assets/*
  Cache-Control: public, max-age=31536000, immutable

/singabldr/boards/*.json
  Cache-Control: public, max-age=0, must-revalidate

/content/*/assets/*
  Cache-Control: public, max-age=31536000, immutable

/content/*/vendor/*
  Cache-Control: public, max-age=31536000, immutable

/__chat_proxy/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/content/singabldr/boards/*.json
  Cache-Control: public, max-age=0, must-revalidate

/content/singabldr/*.json
  Cache-Control: public, max-age=0, must-revalidate
